---
import '../styles/global.css';
import WeekStrip from '../components/WeekStrip.astro';

interface Props {
  week: number;
  title: string;
  subtitle: string;
  dates: string;
  primaryColor: string;
  accentColor: string;
  bgColor: string;
  prevSlug: string | null;
  prevTitle: string | null;
  nextSlug: string | null;
  nextTitle: string | null;
  glassContent?: boolean;
  modelPath?: string;
}

const {
  week,
  title,
  subtitle,
  dates,
  primaryColor,
  accentColor,
  bgColor,
  prevSlug,
  prevTitle,
  nextSlug,
  nextTitle,
  glassContent = false,
  modelPath,
} = Astro.props;

const weekNum = String(week).padStart(2, '0');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={`Setmana ${weekNum} | Erasmus a Amarante, Portugal. Jose & Álvaro.`} />
    <title>Setmana {weekNum} | Amarante Erasmus</title>
    <style define:vars={{ primaryColor, accentColor, bgColor }}>
      :root {
        --week-primary: var(--primaryColor);
        --week-accent:  var(--accentColor);
        --week-bg:      var(--bgColor);
      }
      body {
        background-color: var(--bgColor);
      }
    </style>
  </head>

  <body>
    <!-- NAV -->
    <nav class="site-nav">
      <div class="nav-bar">
        <a href="/" class="nav-home">Amarante '26</a>
        <span class="nav-week">Setmana {weekNum}</span>
        <div class="nav-names">
          <span>Jose</span>
          <span class="sep">×</span>
          <span>Alvaro</span>
        </div>
      </div>
      <WeekStrip currentWeek={week} />
    </nav>

    <!-- THREE.JS CANVAS (fixed, behind everything) -->
    <canvas
      id="three-canvas"
      data-week={week}
      data-primary={primaryColor}
      data-model={modelPath}
      aria-hidden="true"
    ></canvas>

    <!-- HERO -->
    <section class="hero">
      <div class="hero-label">
        <span class="week-badge">Setmana {weekNum}</span>
        <span class="hero-dates">{dates}</span>
      </div>
      <h1 class="hero-title">{title}</h1>
      <p class="hero-subtitle">{subtitle}</p>
      <div class="scroll-hint" aria-hidden="true">
        <span>Scroll</span>
        <div class="scroll-line"></div>
      </div>
    </section>

    <!-- MAIN CONTENT (white, rounded top) -->
    <main class={`week-content${glassContent ? ' week-content--glass' : ''}`}>
      <slot />
    </main>

    <!-- WEEK NAV FOOTER -->
    <footer class="week-footer">
      {
        prevSlug ? (
          <a href={`/${prevSlug}`} class="week-nav-link prev">
            <span class="nav-dir">← Anterior</span>
            <span class="nav-link-title">{prevTitle}</span>
          </a>
        ) : (
          <div class="week-nav-placeholder"></div>
        )
      }
      <span class="week-footer-center">Jose × Alvaro · Erasmus Amarante '26</span>
      {
        nextSlug ? (
          <a href={`/${nextSlug}`} class="week-nav-link next">
            <span class="nav-dir">Següent →</span>
            <span class="nav-link-title">{nextTitle}</span>
          </a>
        ) : (
          <div class="week-nav-placeholder"></div>
        )
      }
    </footer>

    <script>
      import '../scripts/three-week.ts';
    </script>
    <script>
      const nav = document.querySelector('.site-nav');
      window.addEventListener('scroll', () => {
        nav?.classList.toggle('is-scrolled', window.scrollY > 20);
      }, { passive: true });
    </script>
  </body>
</html>
