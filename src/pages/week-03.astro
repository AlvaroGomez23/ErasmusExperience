---
import WeekLayout from '../layouts/WeekLayout.astro';
import { PUBLISHED_WEEKS } from '../config/routes';
if (!PUBLISHED_WEEKS.includes(3)) return Astro.redirect('/');
---

<WeekLayout
  week={3}
  title="03"
  subtitle="Cultura i tradició"
  dates="Setmana 3"
  primaryColor="#E91E8C"
  accentColor="#FF6B35"
  bgColor="#fff0f7"
  prevSlug="week-02"
  prevTitle="Setmana 02"
  nextSlug="week-04"
  nextTitle="Setmana 04"
>
  <section class="content-section">
    <span class="section-tag">Patrimoni</span>
    <h2>Amarante té història</h2>
    <p>
      Museus, esglésies, tradicions. Aquesta setmana ens submergim en la història
      d'Amarante i del nord de Portugal.
    </p>
  </section>

  <section class="content-section">
    <span class="section-tag">Fotos</span>
    <h2>La setmana en imatges</h2>
    <div class="photo-grid">
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
    </div>
  </section>
  <script>
    import '../scripts/three-week-03.ts';
  </script>
</WeekLayout>
