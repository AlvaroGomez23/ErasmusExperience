---
import WeekLayout from '../layouts/WeekLayout.astro';
import { PUBLISHED_WEEKS } from '../config/routes';
if (!PUBLISHED_WEEKS.includes(3)) return Astro.redirect('/');
---

<WeekLayout
  week={3}
  title="03"
  subtitle="Amarante local parties"
  dates="1 – 7 JUN"
  primaryColor="#E91E8C"
  accentColor="#FF6B35"
  bgColor="#0e0014"
  prevSlug="week-02"
  prevTitle="Week 02"
  nextSlug="week-04"
  nextTitle="Week 04"
  modelPath="skip"
  glassContent
>
  <section class="content-section">
    <span class="section-tag">Festival</span>
    <h2>Amarante local parties</h2>
    <p>Adventures coming soon...</p>
