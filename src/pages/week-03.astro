---
import WeekLayout from '../layouts/WeekLayout.astro';
import { PUBLISHED_WEEKS } from '../config/routes';
if (!PUBLISHED_WEEKS.includes(3)) return Astro.redirect('/');
---

<WeekLayout
  week={3}
  title="03"
  subtitle="Culture and tradition"
  dates="Week 3"
  primaryColor="#E91E8C"
  accentColor="#FF6B35"
  bgColor="#fff0f7"
  prevSlug="week-02"
  prevTitle="Week 02"
  nextSlug="week-04"
  nextTitle="Week 04"
>
  <section class="content-section">
    <span class="section-tag">Heritage</span>
    <h2>Amarante has history</h2>
    <p>
      Museums, churches, traditions. This week we dive into the history
      of Amarante and northern Portugal.
    </p>
  </section>

  <section class="content-section">
    <span class="section-tag">Photos</span>
    <h2>The week in images</h2>
    <div class="photo-grid">
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
    </div>
  </section>
  <script>
    import '../scripts/three-week-03.ts';
  </script>
</WeekLayout>
