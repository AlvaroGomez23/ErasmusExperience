---
import WeekLayout from '../layouts/WeekLayout.astro';
import { PUBLISHED_WEEKS } from '../config/routes';
if (!PUBLISHED_WEEKS.includes(9)) return Astro.redirect('/');
---

<WeekLayout
  week={9}
  title="09"
  subtitle="Natura i muntanyes"
  dates="Setmana 9"
  primaryColor="#4CAF50"
  accentColor="#88CE02"
  bgColor="#f0fff4"
  prevSlug="week-08"
  prevTitle="Setmana 08"
  nextSlug="week-10"
  nextTitle="Setmana 10"
>
  <section class="content-section">
    <span class="section-tag">Terra</span>
    <h2>El nord verd</h2>
    <p>
      Portugal del nord és verd i salvatge. Aquesta setmana ens perdem en
      la natura — senders, cascades i vistes que no s'obliden.
    </p>
  </section>

  <section class="content-section">
    <span class="section-tag">Fotos</span>
    <h2>La setmana en imatges</h2>
    <div class="photo-grid">
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
    </div>
  </section>
  <script>
    import '../scripts/three-week-09.ts';
  </script>
</WeekLayout>
