---
import WeekLayout from '../layouts/WeekLayout.astro';
import { PUBLISHED_WEEKS } from '../config/routes';
if (!PUBLISHED_WEEKS.includes(9)) return Astro.redirect('/');
---

<WeekLayout
  week={9}
  title="09"
  subtitle="Nature and mountains"
  dates="Week 9"
  primaryColor="#4CAF50"
  accentColor="#88CE02"
  bgColor="#f0fff4"
  prevSlug="week-08"
  prevTitle="Week 08"
  nextSlug="week-10"
  nextTitle="Week 10"
>
  <section class="content-section">
    <span class="section-tag">Land</span>
    <h2>The green north</h2>
    <p>
      Northern Portugal is green and wild. This week we get lost in
      nature — trails, waterfalls, and views you never forget.
    </p>
  </section>

  <section class="content-section">
    <span class="section-tag">Photos</span>
    <h2>The week in images</h2>
    <div class="photo-grid">
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
    </div>
  </section>
  <script>
    import '../scripts/three-week-09.ts';
  </script>
</WeekLayout>
