---
import WeekLayout from '../layouts/WeekLayout.astro';
import { PUBLISHED_WEEKS } from '../config/routes';
if (!PUBLISHED_WEEKS.includes(5)) return Astro.redirect('/');
---

<WeekLayout
  week={5}
  title="05"
  subtitle="The Tâmega River"
  dates="Week 5"
  primaryColor="#00BCD4"
  accentColor="#88CE02"
  bgColor="#f0fbff"
  prevSlug="week-04"
  prevTitle="Week 04"
  nextSlug="week-06"
  nextTitle="Week 06"
>
  <section class="content-section">
    <span class="section-tag">Water</span>
    <h2>The Tâmega runs slow</h2>
    <p>
      The Tâmega river defines Amarante. This week we explore it from its banks,
      its bridges, and its cold northern waters.
    </p>
  </section>

  <section class="content-section">
    <span class="section-tag">Photos</span>
    <h2>The week in images</h2>
    <div class="photo-grid">
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
    </div>
  </section>
  <script>
    import '../scripts/three-week-05.ts';
  </script>
</WeekLayout>
