---
import WeekLayout from '../layouts/WeekLayout.astro';
import { PUBLISHED_WEEKS } from '../config/routes';
if (!PUBLISHED_WEEKS.includes(6)) return Astro.redirect('/');
---

<WeekLayout
  week={6}
  title="06"
  subtitle="Aventura pels voltants"
  dates="Setmana 6"
  primaryColor="#9C27B0"
  accentColor="#E91E8C"
  bgColor="#f9f0ff"
  prevSlug="week-05"
  prevTitle="Setmana 05"
  nextSlug="week-07"
  nextTitle="Setmana 07"
>
  <section class="content-section">
    <span class="section-tag">Rutes</span>
    <h2>Més enllà d'Amarante</h2>
    <p>
      Porto a una hora, el Douro a mitja hora. Aquesta setmana sortim a explorar
      els voltants del nord de Portugal.
    </p>
  </section>

  <section class="content-section">
    <span class="section-tag">Fotos</span>
    <h2>La setmana en imatges</h2>
    <div class="photo-grid">
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
    </div>
  </section>
  <script>
    import '../scripts/three-week-06.ts';
  </script>
</WeekLayout>
