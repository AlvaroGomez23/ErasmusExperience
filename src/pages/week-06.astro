---
import WeekLayout from '../layouts/WeekLayout.astro';
import { PUBLISHED_WEEKS } from '../config/routes';
if (!PUBLISHED_WEEKS.includes(6)) return Astro.redirect('/');
---

<WeekLayout
  week={6}
  title="06"
  subtitle="Adventures around the area"
  dates="Week 6"
  primaryColor="#9C27B0"
  accentColor="#E91E8C"
  bgColor="#f9f0ff"
  prevSlug="week-05"
  prevTitle="Week 05"
  nextSlug="week-07"
  nextTitle="Week 07"
>
  <section class="content-section">
    <span class="section-tag">Routes</span>
    <h2>Beyond Amarante</h2>
    <p>
      Porto one hour away, the Douro half an hour. This week we head out to explore
      the surroundings of northern Portugal.
    </p>
  </section>

  <section class="content-section">
    <span class="section-tag">Photos</span>
    <h2>The week in images</h2>
    <div class="photo-grid">
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
    </div>
  </section>
  <script>
    import '../scripts/three-week-06.ts';
  </script>
</WeekLayout>
