---
import WeekLayout from '../layouts/WeekLayout.astro';
import { PUBLISHED_WEEKS } from '../config/routes';
if (!PUBLISHED_WEEKS.includes(8)) return Astro.redirect('/');
---

<WeekLayout
  week={8}
  title="08"
  subtitle="Cuina portuguesa"
  dates="Setmana 8"
  primaryColor="#FF9800"
  accentColor="#FF6B35"
  bgColor="#fff8f0"
  prevSlug="week-07"
  prevTitle="Setmana 07"
  nextSlug="week-09"
  nextTitle="Setmana 09"
>
  <section class="content-section">
    <span class="section-tag">Gastronomia</span>
    <h2>Menjar a Portugal</h2>
    <p>
      Bacallà de mil maneres, francesinha, pastel de nata, vinho verde.
      Aquesta setmana la dediquem a menjar bé (i sense culpa).
    </p>
  </section>

  <section class="content-section">
    <span class="section-tag">Fotos</span>
    <h2>La setmana en imatges</h2>
    <div class="photo-grid">
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
    </div>
  </section>
  <script>
    import '../scripts/three-week-08.ts';
  </script>
</WeekLayout>
