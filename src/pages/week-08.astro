---
import WeekLayout from '../layouts/WeekLayout.astro';
import { PUBLISHED_WEEKS } from '../config/routes';
if (!PUBLISHED_WEEKS.includes(8)) return Astro.redirect('/');
---

<WeekLayout
  week={8}
  title="08"
  subtitle="Portuguese cuisine"
  dates="Week 8"
  primaryColor="#FF9800"
  accentColor="#FF6B35"
  bgColor="#fff8f0"
  prevSlug="week-07"
  prevTitle="Week 07"
  nextSlug="week-09"
  nextTitle="Week 09"
>
  <section class="content-section">
    <span class="section-tag">Gastronomy</span>
    <h2>Eating in Portugal</h2>
    <p>
      Bacalhau a thousand ways, francesinha, pastel de nata, vinho verde.
      This week we dedicate ourselves to eating well (guilt-free).
    </p>
  </section>

  <section class="content-section">
    <span class="section-tag">Photos</span>
    <h2>The week in images</h2>
    <div class="photo-grid">
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
    </div>
  </section>
  <script>
    import '../scripts/three-week-08.ts';
  </script>
</WeekLayout>
