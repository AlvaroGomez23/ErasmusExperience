---
import { weeks } from '../data/weeks';
import '../styles/global.css';
import WeekStrip from '../components/WeekStrip.astro';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Erasmus a Amarante, Portugal 2026 — Jose i Álvaro. 10 setmanes, mil records." />
    <title>Amarante Erasmus '26 — Jose & Álvaro</title>
    <style>
      :root {
        --week-primary: #88CE02;
        --week-bg: #f0f7e6;
      }
      body { background-color: #f8f5ee; }
    </style>
  </head>

  <body>
    <!-- NAV -->
    <nav class="site-nav">
      <div class="nav-bar">
        <span class="nav-home" style="cursor:default">Amarante '26</span>
        <span class="nav-week">Portugal</span>
        <div class="nav-names">
          <span>Jose</span>
          <span class="sep">×</span>
          <span>Alvaro</span>
        </div>
      </div>
      <WeekStrip />
    </nav>

    <!-- THREE.JS CANVAS -->
    <canvas id="three-canvas" aria-hidden="true"></canvas>

    <!-- SITE HERO -->
    <section class="site-hero">
      <p class="site-tagline">Erasmus · Amarante · Portugal · 2026</p>
      <h1 class="site-title">
        AMARANTE
      </h1>
      <div class="site-meta">
        <div><strong>Jose & Álvaro</strong></div>
        <div>10 setmanes</div>
        <div>Nord de Portugal</div>
        <div>Erasmus+</div>
      </div>
      <div class="scroll-hint" style="margin-top:2rem" aria-hidden="true">
        <span>Explorar</span>
        <div class="scroll-line"></div>
      </div>
    </section>

    <!-- WEEKS GRID -->
    <section class="weeks-section">
      <div class="weeks-section-header content-section">
        <span class="section-tag">El viatge</span>
        <h2>10 setmanes a Portugal</h2>
      </div>

      <div class="weeks-grid">
        {
          weeks.map((w, i) => (
            <a
              href={`/${w.slug}`}
              class="week-card"
              style={`background-color:${w.bgColor}; border: 2px solid ${w.primaryColor}20;`}
              data-index={i}
            >
              <span class="card-num">Setmana {String(w.week).padStart(2, '0')}</span>
              <div>
                <div
                  class="card-week-title"
                  style={`color:${w.primaryColor}`}
                >
                  {w.title}
                </div>
                <div class="card-dates">{w.subtitle}</div>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <!-- ABOUT -->
    <section class="about-section">
      <div class="about-inner content-section" style="max-width:900px;margin:0 auto;">
        <div>
          <div class="about-name">
            Jose<span>&</span>Alvaro
          </div>
        </div>
        <div class="about-text">
          <p>
            Dos germans, una ciutat petita al nord de Portugal, i deu setmanes per
            explorar-ho tot. Aquest és el nostre diari d'Erasmus a Amarante.
          </p>
          <p>
            Cada setmana té la seva pròpia història: llocs, persones, menjar, aventures
            i els moments que no teníem planejats.
          </p>
        </div>
      </div>
    </section>

    <script>
      import '../scripts/three-index.ts';
    </script>
    <script>
      const nav = document.querySelector('.site-nav');
      window.addEventListener('scroll', () => {
        nav?.classList.toggle('is-scrolled', window.scrollY > 20);
      }, { passive: true });
    </script>
  </body>
</html>
