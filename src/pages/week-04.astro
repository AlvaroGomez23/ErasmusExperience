---
import WeekLayout from '../layouts/WeekLayout.astro';
import { PUBLISHED_WEEKS } from '../config/routes';
if (!PUBLISHED_WEEKS.includes(4)) return Astro.redirect('/');
---

<WeekLayout
  week={4}
  title="04"
  subtitle="New people, new friends"
  dates="Week 4"
  primaryColor="#FFD700"
  accentColor="#FF6B35"
  bgColor="#fffbf0"
  prevSlug="week-03"
  prevTitle="Week 03"
  nextSlug="week-05"
  nextTitle="Week 05"
>
  <section class="content-section">
    <span class="section-tag">People</span>
    <h2>The ones who make the journey</h2>
    <p>
      An Erasmus isn't just about places. It's the people you meet, the conversations
      at 2 in the morning, the unexpected adventure companions.
    </p>
  </section>

  <section class="content-section">
    <span class="section-tag">Photos</span>
    <h2>The week in images</h2>
    <div class="photo-grid">
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
    </div>
  </section>
  <script>
    import '../scripts/three-week-04.ts';
  </script>
</WeekLayout>
