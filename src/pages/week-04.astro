---
import WeekLayout from '../layouts/WeekLayout.astro';
import { PUBLISHED_WEEKS } from '../config/routes';
if (!PUBLISHED_WEEKS.includes(4)) return Astro.redirect('/');
---

<WeekLayout
  week={4}
  title="04"
  subtitle="Nova gent, nous amics"
  dates="Setmana 4"
  primaryColor="#FFD700"
  accentColor="#FF6B35"
  bgColor="#fffbf0"
  prevSlug="week-03"
  prevTitle="Setmana 03"
  nextSlug="week-05"
  nextTitle="Setmana 05"
>
  <section class="content-section">
    <span class="section-tag">Persones</span>
    <h2>Els que fan el viatge</h2>
    <p>
      Un Erasmus no és només els llocs. És la gent que coneixes, les converses
      a les 2 de la matinada, els companys d'aventura inesperats.
    </p>
  </section>

  <section class="content-section">
    <span class="section-tag">Fotos</span>
    <h2>La setmana en imatges</h2>
    <div class="photo-grid">
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
    </div>
  </section>
  <script>
    import '../scripts/three-week-04.ts';
  </script>
</WeekLayout>
