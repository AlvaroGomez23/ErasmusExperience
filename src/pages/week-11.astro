---
import WeekLayout from '../layouts/WeekLayout.astro';
import { PUBLISHED_WEEKS } from '../config/routes';
if (!PUBLISHED_WEEKS.includes(11)) return Astro.redirect('/');
---

<WeekLayout
  week={11}
  title="11"
  subtitle="Last days, eternal memories"
  dates="Week 11"
  primaryColor="#2196F3"
  accentColor="#00BCD4"
  bgColor="#f0f7ff"
  prevSlug="week-10"
  prevTitle="Week 10"
  nextSlug={null}
  nextTitle={null}
>
  <section class="content-section">
    <span class="section-tag">Farewell</span>
    <h2>All things end</h2>
    <p>
      The last week always comes too soon. Bags packed, goodbyes,
      and that strange feeling of leaving a place that already feels like home.
    </p>
    <p>
      Ten weeks in Amarante. We wouldn't trade them for anything.
    </p>
  </section>

  <section class="content-section">
    <span class="section-tag">Reflection</span>
    <h2>What we learned</h2>
    <p>
      Write the final Erasmus reflection here — what you're taking with you, what
      changed, what you'd do again and what you wouldn't.
    </p>
  </section>

  <section class="content-section">
    <span class="section-tag">Photos</span>
    <h2>The week in images</h2>
    <div class="photo-grid">
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
    </div>
  </section>
  <script>
    import '../scripts/three-week-11.ts';
  </script>
</WeekLayout>
