---
import WeekLayout from '../layouts/WeekLayout.astro';
---

<WeekLayout
  week={2}
  title="02"
  subtitle="Explorant la ciutat"
  dates="Setmana 2"
  primaryColor="#FF6B35"
  accentColor="#FFD700"
  bgColor="#fff5f0"
  prevSlug="week-01"
  prevTitle="Setmana 01"
  nextSlug="week-03"
  nextTitle="Setmana 03"
>
  <canvas
    id="float-canvas"
    aria-hidden="true"
    style="position:fixed;inset:0;width:100%;height:100%;z-index:11;pointer-events:none;"
  ></canvas>

  <section class="content-section">
    <span class="section-tag">Descoberta</span>
    <h2>La ciutat s'obre</h2>
    <p>
      Segona setmana i ja comencem a conèixer els racons més amagats.
      El mercat, els miradors, els carrers del casc històric.
    </p>
    <p>
      Aquesta mateixa setmana, van començar les pràctiques a l'empresa anomenada CodeAhead. Una empresa local que es dedica al desenvolupament de software, on vam tenir l'oportunitat d'aplicar els nostres coneixements, apendre del nostre tutor, aplicant models 3D i animacions modernes sense deixar els temps lliures per explorar la ciutat.
    </p>
  </section>

  <section class="content-section">
    <span class="section-tag">Moments clau</span>
    <h2>Highlights</h2>
    <div class="highlights">
      <div class="highlight-card">
        <span class="h-icon">🗺️</span>
        <div class="h-title">Mapa a la mà</div>
        <div class="h-desc">Perduts i trobats</div>
      </div>
      <div class="highlight-card">
        <span class="h-icon">☕</span>
        <div class="h-title">Les cafeteries</div>
        <div class="h-desc">Pastel de nata i cafè</div>
      </div>
      <div class="highlight-card">
        <span class="h-icon">🏔️</span>
        <div class="h-title">Les vistes</div>
        <div class="h-desc">El Tâmega des de dalt</div>
      </div>
      <div class="highlight-card">
        <span class="h-icon">🛍️</span>
        <div class="h-title">El mercat</div>
        <div class="h-desc">Dissabte al mercat local</div>
      </div>
    </div>
  </section>

  <section class="content-section">
    <span class="section-tag">Fotos</span>
    <h2>La setmana en imatges</h2>
    <div class="photo-grid">
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
    </div>
  </section>

  <script>
    import '../scripts/models-week02.ts';
  </script>
</WeekLayout>
