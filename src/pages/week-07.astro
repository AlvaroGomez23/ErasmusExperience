---
import WeekLayout from '../layouts/WeekLayout.astro';
import { PUBLISHED_WEEKS } from '../config/routes';
if (!PUBLISHED_WEEKS.includes(7)) return Astro.redirect('/');
---

<WeekLayout
  week={7}
  title="07"
  subtitle="Art and creativity"
  dates="Week 7"
  primaryColor="#FF4444"
  accentColor="#FFD700"
  bgColor="#fff0f0"
  prevSlug="week-06"
  prevTitle="Week 06"
  nextSlug="week-08"
  nextTitle="Week 08"
>
  <section class="content-section">
    <span class="section-tag">Creativity</span>
    <h2>Amarante and art</h2>
    <p>
      Amadeo de Souza-Cardoso was born here. Art is in the DNA of this city.
      This week we see everything through an artist's eyes.
    </p>
  </section>

  <section class="content-section">
    <span class="section-tag">Photos</span>
    <h2>The week in images</h2>
    <div class="photo-grid">
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
    </div>
  </section>
  <script>
    import '../scripts/three-week-07.ts';
  </script>
</WeekLayout>
