---
import '../styles/global.css';
import WeekStrip from '../components/WeekStrip.astro';

const supabaseConfig = JSON.stringify({
  url: import.meta.env.SUPABASE_URL,
  key: import.meta.env.SUPABASE_KEY,
});
---
<!-- NOTA: PONER CHISMES -->
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/webp" href="/photos/Flag_of_Europe.svg.webp" />
    <title>★ Secret Party ★</title>
    <style>
      body {
        background: #080810;
        color: #f0f0ff;
        overflow: hidden;
      }
      body.unlocked {
        overflow-x: hidden;
        overflow-y: auto;
      }

      /* ── GATE ─────────────────────────────────── */
      #gate {
        position: fixed;
        inset: 0;
        z-index: 200;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(8, 8, 16, 0.88);
        transition: opacity 0.7s ease, visibility 0.7s ease;
      }
      #gate.hidden {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
      }
      .gate-box {
        text-align: center;
        padding: 3rem 2.5rem;
        max-width: 500px;
        width: 100%;
      }
      .gate-tag {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.35em;
        color: #ff006e;
        margin-bottom: 2rem;
        opacity: 0.8;
      }
      .gate-title {
        font-family: var(--font-display);
        font-size: clamp(5rem, 18vw, 10rem);
        font-weight: 900;
        line-height: 0.85;
        text-transform: uppercase;
        letter-spacing: -0.04em;
        color: #fff;
        margin-bottom: 3rem;
        text-shadow:
          0 0 40px rgba(255, 0, 110, 0.7),
          0 0 80px rgba(131, 56, 236, 0.5),
          0 0 160px rgba(255, 0, 110, 0.2);
      }
      .gate-form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        align-items: center;
      }
      #gate-input {
        width: 100%;
        max-width: 280px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 0, 110, 0.45);
        border-radius: 99px;
        padding: 0.9rem 1.6rem;
        font-family: var(--font-mono);
        font-size: 1.05rem;
        letter-spacing: 0.35em;
        text-align: center;
        color: #fff;
        outline: none;
        transition: border-color 0.25s, box-shadow 0.25s;
      }
      #gate-input:focus {
        border-color: #ff006e;
        box-shadow: 0 0 0 3px rgba(255, 0, 110, 0.15), 0 0 24px rgba(255, 0, 110, 0.25);
      }
      #gate-input::placeholder {
        opacity: 0.35;
        letter-spacing: 0.2em;
        font-size: 0.85rem;
      }
      #gate-btn {
        padding: 0.85rem 2.8rem;
        border-radius: 99px;
        border: none;
        background: linear-gradient(135deg, #ff006e 0%, #8338ec 100%);
        color: #fff;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 4px 24px rgba(255, 0, 110, 0.35);
      }
      #gate-btn:hover {
        opacity: 0.88;
        transform: translateY(-2px);
        box-shadow: 0 10px 35px rgba(255, 0, 110, 0.5);
      }
      #gate-error {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: #ff4444;
        min-height: 1.2em;
      }
      #gate-escape {
        display: inline-flex;
        align-items: center;
        gap: 0.5em;
        margin-top: 2.8rem;
        padding: 0.6rem 1.4rem;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.14em;
        text-decoration: none;
        color: rgba(255, 255, 255, 0.55);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 99px;
        animation: escapeBreath 2.8s ease-in-out infinite;
        transition: color 0.25s, border-color 0.25s, background 0.25s;
      }
      #gate-escape:hover {
        color: #fff;
        border-color: rgba(255, 255, 255, 0.5);
        background: rgba(255, 255, 255, 0.07);
        animation: none;
      }
      @keyframes escapeBreath {
        0%, 100% { opacity: 0.45; }
        50%       { opacity: 1; }
      }
      @keyframes shakeGate {
        0%, 100% { transform: translateX(0); }
        20%       { transform: translateX(-14px); }
        40%       { transform: translateX(11px); }
        60%       { transform: translateX(-8px); }
        80%       { transform: translateX(5px); }
      }
      .gate-box.shake { animation: shakeGate 0.45s ease; }

      /* ── PARTY CONTENT ────────────────────────── */
      #party-content {
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.6s 0.45s;
      }
      #party-content.visible {
        opacity: 1;
        pointer-events: auto;
      }

      /* ── NAV (dark override, matches week-03 style) ── */
      .nav-home             { color: #f0f0ff; }
      .nav-home:hover       { color: #ff006e; }
      .nav-week, .nav-names { color: #f0f0ff; }
      .site-nav {
        background:   rgba(8, 8, 16, 0.55);
        border-color: rgba(255, 0, 110, 0.2);
      }
      .site-nav.is-scrolled {
        background:   rgba(8, 8, 16, 0.85);
        border-color: rgba(255, 0, 110, 0.45);
        box-shadow: 0 8px 40px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.06);
      }

      /* ── PARTY HERO ───────────────────────────── */
      .party-hero {
        position: relative;
        z-index: 10;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 0 2.5rem 4.5rem;
      }
      .party-tagline {
        font-family: var(--font-mono);
        font-size: 0.82rem;
        text-transform: uppercase;
        letter-spacing: 0.28em;
        color: #ff006e;
        margin-bottom: 1.5rem;
        opacity: 0.85;
      }
      .party-title {
        font-size: clamp(5rem, 18vw, 500rem);
        font-weight: 900;
        line-height: 0.82;
        letter-spacing: -0.04em;
        text-transform: uppercase;
        color: #fff;
        text-shadow:
          0 0 60px rgba(255, 0, 110, 0.55),
          0 0 120px rgba(131, 56, 236, 0.4),
          0 0 200px rgba(255, 0, 110, 0.15);
        will-change: transform;
        position: relative;
        width: calc(100% + 5rem);
      }
      .party-meta {
        display: flex;
        gap: 3rem;
        margin-top: 2.5rem;
        font-family: var(--font-mono);
        font-size: 0.85rem;
        opacity: 0.5;
        color: #f0f0ff;
        flex-wrap: wrap;
      }
      .party-meta strong {
        opacity: 1;
        color: #ff006e;
      }

      /* ── PHOTO SECTION ────────────────────────── */
      .party-photos {
        position: relative;
        z-index: 10;
        background: #0e0e1a;
        border-radius: 2rem 2rem 0 0;
        padding: 5rem 2.5rem 7rem;
        box-shadow:
          0 -24px 80px rgba(255, 0, 110, 0.12),
          0 -3px 0 rgba(255, 0, 110, 0.18);
      }
      .party-inner {
        max-width: 1100px;
        margin: 0 auto;
      }
      .party-section-tag {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: #ff006e;
        margin-bottom: 1.2rem;
      }
      .party-section-title {
        font-size: clamp(2rem, 5vw, 4rem);
        font-weight: 900;
        line-height: 0.95;
        text-transform: uppercase;
        letter-spacing: -0.02em;
        color: #fff;
        text-shadow: 0 0 30px rgba(255, 0, 110, 0.35);
        margin-bottom: 3.5rem;
      }

      /* ── PHOTO GRID (party colours) ─────────────── */
      .party-photos { --week-primary: #ff006e; }

      .photo-skeleton {
        aspect-ratio: 4 / 3;
        border-radius: 1.2rem;
        background: linear-gradient(90deg, #1a1a2e 25%, #25254e 50%, #1a1a2e 75%);
        background-size: 200% 100%;
        animation: shimmer-dark 1.4s infinite;
      }
      @keyframes shimmer-dark {
        0%   { background-position:  200% 0; }
        100% { background-position: -200% 0; }
      }
      .no-photos {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: #f0f0ff;
        opacity: 0.35;
        padding: 3rem 0;
        text-align: center;
        grid-column: 1 / -1;
      }

      /* ── LIGHTBOX ────────────────────────────── */
      #lightbox {
        position: fixed;
        inset: 0;
        z-index: 1000;
        background: rgba(5, 5, 14, 0.97);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.25s;
        cursor: zoom-out;
      }
      #lightbox.visible { opacity: 1; pointer-events: auto; }
      #lightbox img {
        max-width: 90vw;
        max-height: 90vh;
        object-fit: contain;
        border-radius: 6px;
        display: block;
        cursor: default;
      }
      #lightbox-close {
        position: fixed;
        top: 1.5rem;
        right: 1.5rem;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: 1px solid rgba(255, 0, 110, 0.4);
        background: none;
        color: rgba(255,255,255,0.7);
        font-size: 1.1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
      }
      #lightbox-close:hover { border-color: #ff006e; color: #fff; }

      /* ── FOOTER ───────────────────────────────── */
      .party-footer {
        position: relative;
        z-index: 10;
        background: #0e0e1a;
        padding: 3rem 2.5rem;
        display: flex;
        justify-content: center;
        border-top: 1px solid rgba(255, 0, 110, 0.12);
      }
      .party-footer span {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        opacity: 0.35;
        color: #f0f0ff;
      }

      /* ── RESPONSIVE ───────────────────────────── */
      @media (min-width: 769px) {
        .gate-title { transform: translateX(-8%); }
      }
      @media (max-width: 768px) {
        .party-hero { padding: 0 1.5rem 3.5rem; }
        .party-title { left: -1.5rem; width: calc(100% + 3rem); }
        .party-photos { padding: 3.5rem 1.5rem 4rem; }
      }
    </style>
    <style is:global>
      .week-strip { border-color: rgba(255, 0, 110, 0.15); }
      .week-dot {
        color:        rgba(255, 255, 255, 0.65);
        border-color: rgba(255, 255, 255, 0.15);
        opacity:      1;
      }
      .week-dot:hover {
        color:        var(--dot-color);
        border-color: var(--dot-color);
      }
      .week-dot.active {
        color:   #fff;
        opacity: 1;
      }
    </style>
  </head>

  <body>
    <script id="sb-config" type="application/json" set:html={supabaseConfig}></script>

    <!-- THREE.JS CANVAS -->
    <canvas id="three-canvas" aria-hidden="true"></canvas>

    <!-- PASSWORD GATE -->
    <div id="gate">
      <div class="gate-box">
        <p class="gate-tag">&#10022; Secret Access Only &#10022;</p>
        <h1 class="gate-title">PARTY</h1>
        <div class="gate-form">
          <input
            type="password"
            id="gate-input"
            placeholder="enter the code"
            autocomplete="off"
            spellcheck="false"
          />
          <button id="gate-btn">UNLOCK &#10022;</button>
          <p id="gate-error" aria-live="polite"></p>
        </div>
        <a href="/" id="gate-escape">&#8592; take me back home</a>
      </div>
    </div>

    <!-- PARTY CONTENT -->
    <div id="party-content">
      <!-- NAV -->
      <nav class="site-nav">
        <div class="nav-bar">
          <a href="/" class="nav-home">Amarante '26</a>
          <span class="nav-week">Party</span>
          <div class="nav-names">
            <span>Jose</span>
            <span class="sep" style="opacity:0.35">×</span>
            <span>Alvaro</span>
          </div>
        </div>
        <WeekStrip />
      </nav>

      <!-- HERO -->
      <section class="party-hero">
        <p class="party-tagline">&#9733; Top Secret &#9733;</p>
        <h1 class="party-title">THE NIGHTS</h1>
        <div class="party-meta">
          <div><strong>The Nights</strong></div>
          <div>Amarante, Portugal</div>
          <div>2026</div>
        </div>
        <div class="scroll-hint" style="margin-top:2rem;color:#ff006e;opacity:0.5" aria-hidden="true">
          <span>Scroll</span>
          <div class="scroll-line"></div>
        </div>
      </section>

      <!-- PHOTOS -->
      <main class="party-photos">
        <div class="party-inner">
          <span class="party-section-tag">&#9733; Private Collection</span>
          <h2 class="party-section-title">The Nights We Won't Forget</h2>
          <div class="photo-grid" id="photos-party">
            <div class="photo-skeleton"></div>
            <div class="photo-skeleton"></div>
            <div class="photo-skeleton"></div>
            <div class="photo-skeleton"></div>
          </div>
        </div>
      </main>

      <!-- FOOTER -->
      <footer class="party-footer">
        <span>Jose × Alvaro · Erasmus Amarante '26 · Classified</span>
      </footer>

    </div>

    <!-- LIGHTBOX -->
    <div id="lightbox">
      <img id="lightbox-img" src="" alt="" />
      <button id="lightbox-close" aria-label="Close">&#10005;</button>
    </div>

    <script>
      const PASSWORD = 'FIESTA';
      const SESSION_KEY = 'party_unlocked';

      const gate    = document.getElementById('gate')!;
      const gateBox = gate.querySelector('.gate-box') as HTMLElement;
      const input   = document.getElementById('gate-input') as HTMLInputElement;
      const btn     = document.getElementById('gate-btn')!;
      const errEl   = document.getElementById('gate-error')!;
      const content = document.getElementById('party-content')!;

      function unlock() {
        gate.classList.add('hidden');
        content.classList.add('visible');
        document.body.classList.add('unlocked');
        sessionStorage.setItem(SESSION_KEY, '1');
      }

      if (sessionStorage.getItem(SESSION_KEY) === '1') {
        gate.style.display = 'none';
        content.classList.add('visible');
        document.body.classList.add('unlocked');
      }

      btn.addEventListener('click', () => {
        if (input.value.trim().toUpperCase() === PASSWORD) {
          unlock();
        } else {
          errEl.textContent = '✗ Wrong code. Try again.';
          gateBox.classList.remove('shake');
          void gateBox.offsetWidth;
          gateBox.classList.add('shake');
          input.value = '';
          input.focus();
        }
      });

      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') btn.click();
        errEl.textContent = '';
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !gate.classList.contains('hidden')) {
          window.location.href = '/';
        }
      });
    </script>

    <script>
      import { createClient } from '@supabase/supabase-js';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      const config = JSON.parse(document.getElementById('sb-config')!.textContent!);
      const supabase = createClient(config.url, config.key);
      const BUCKET = 'Photos';
      const PHOTO_EXT_RE = /\.(jpe?g|webp|png)$/i;
      const INITIAL = 9;

      function openLightbox(url: string, alt: string) {
        const lb  = document.getElementById('lightbox')!;
        const img = document.getElementById('lightbox-img') as HTMLImageElement;
        img.src = url;
        img.alt = alt;
        lb.classList.add('visible');
        document.body.style.overflow = 'hidden';
      }

      function closeLightbox() {
        document.getElementById('lightbox')!.classList.remove('visible');
        document.body.style.overflow = '';
      }

      document.getElementById('lightbox')!.addEventListener('click', (e) => {
        if (e.target === e.currentTarget) closeLightbox();
      });
      document.getElementById('lightbox-close')!.addEventListener('click', closeLightbox);
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });

      async function loadPartyPhotos() {
        const gridEl = document.getElementById('photos-party')!;

        const { data, error } = await supabase.storage.from(BUCKET).list('party', {
          limit: 200,
          sortBy: { column: 'name', order: 'asc' },
        });

        if (error || !data) {
          gridEl.innerHTML = '<p class="no-photos">Could not load photos.</p>';
          return;
        }

        const photos = data.filter(f => PHOTO_EXT_RE.test(f.name));

        if (photos.length === 0) {
          gridEl.innerHTML = '<p class="no-photos">Coming soon.</p>';
          return;
        }

        const urls = photos.map(f =>
          supabase.storage.from(BUCKET).getPublicUrl(`party/${f.name}`).data.publicUrl
        );

        gridEl.innerHTML = '';

        function renderBatch(batch: string[], offset: number) {
          batch.forEach((url, i) => {
            const alt = `Party · Photo ${offset + i + 1}`;
            const item = document.createElement('div');
            item.className = 'photo-item';
            const img = document.createElement('img');
            img.src = url;
            img.alt = alt;
            img.loading = 'lazy';
            item.addEventListener('click', () => openLightbox(url, alt));
            item.appendChild(img);
            gridEl.appendChild(item);
          });
        }

        renderBatch(urls.slice(0, INITIAL), 0);

        if (urls.length > INITIAL) {
          const fade = document.createElement('div');
          fade.className = 'grid-fade';
          fade.style.background = 'linear-gradient(to bottom, transparent, #0e0e1a)';
          gridEl.after(fade);

          const btn = document.createElement('button');
          btn.className = 'show-more-btn';
          btn.textContent = `↓  ${urls.length - INITIAL} more`;
          fade.after(btn);

          btn.addEventListener('click', () => {
            renderBatch(urls.slice(INITIAL), INITIAL);
            fade.remove();
            btn.remove();
            ScrollTrigger.refresh();
          });
        }
      }

      const content = document.getElementById('party-content')!;
      if (content.classList.contains('visible')) {
        loadPartyPhotos();
      } else {
        const obs = new MutationObserver(() => {
          if (content.classList.contains('visible')) {
            obs.disconnect();
            loadPartyPhotos();
          }
        });
        obs.observe(content, { attributes: true, attributeFilter: ['class'] });
      }
    </script>

    <script>
      import '../scripts/three-party.ts';
    </script>
    <script>
      import '../scripts/cursor.ts';
    </script>
    <script>
      const nav = document.querySelector('.site-nav');
      window.addEventListener('scroll', () => {
        nav?.classList.toggle('is-scrolled', window.scrollY > 20);
      }, { passive: true });
    </script>
  </body>
</html>
