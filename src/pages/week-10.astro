---
import WeekLayout from '../layouts/WeekLayout.astro';
import { PUBLISHED_WEEKS } from '../config/routes';
if (!PUBLISHED_WEEKS.includes(10)) return Astro.redirect('/');
---

<WeekLayout
  week={10}
  title="10"
  subtitle="Últims dies, records eterns"
  dates="Setmana 10"
  primaryColor="#2196F3"
  accentColor="#00BCD4"
  bgColor="#f0f7ff"
  prevSlug="week-09"
  prevTitle="Setmana 09"
  nextSlug={null}
  nextTitle={null}
>
  <section class="content-section">
    <span class="section-tag">Comiat</span>
    <h2>Tot té un final</h2>
    <p>
      L'última setmana sempre arriba massa aviat. Maletes fetes, adéus,
      i aquella sensació estranya de deixar un lloc que ja sents teu.
    </p>
    <p>
      Deu setmanes a Amarante. No les canviem per res.
    </p>
  </section>

  <section class="content-section">
    <span class="section-tag">Reflexió</span>
    <h2>El que vam aprendre</h2>
    <p>
      Escriu aquí la reflexió final de l'Erasmus — què us endporteu, què
      va canviar, què repetiríeu i què no.
    </p>
  </section>

  <section class="content-section">
    <span class="section-tag">Fotos</span>
    <h2>La setmana en imatges</h2>
    <div class="photo-grid">
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
      <div class="photo-item">📸</div>
    </div>
  </section>
  <script>
    import '../scripts/three-week-10.ts';
  </script>
</WeekLayout>
