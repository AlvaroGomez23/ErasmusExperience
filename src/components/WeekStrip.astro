---
import { weeks } from '../data/weeks';
import { PUBLISHED_WEEKS } from '../config/routes';

interface Props {
  currentWeek?: number;
}
const { currentWeek } = Astro.props;
---

<div class="week-strip" role="navigation" aria-label="Week navigation">
  {weeks.filter((w) => PUBLISHED_WEEKS.includes(w.week)).map((w) => (
    <a
      href={`/${w.slug}`}
      class={`week-dot${currentWeek === w.week ? ' active' : ''}`}
      style={`--dot-color:${w.primaryColor}`}
      aria-current={currentWeek === w.week ? 'page' : undefined}
    >
      {String(w.week).padStart(2, '0')}
    </a>
  ))}
  <a
    href="/gallery"
    class={`week-dot${Astro.url?.pathname === '/gallery' ? ' active' : ''}`}
    style="--dot-color:#88CE02"
  >
    Gallery
  </a>
</div>
